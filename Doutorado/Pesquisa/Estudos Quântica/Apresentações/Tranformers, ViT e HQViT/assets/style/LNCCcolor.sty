% LNCCcolor.sty - Color definitions for the National Laboratory for Scientific Computing (LNCC) presentations and documents.
%
% This file implements the official color scheme of LNCC, based on the LNCC Brand Identity Manual (v1.1, April 2023),
% available at: https://www.gov.br/lncc/pt-br/acesso-a-informacao/institucional/manual-de-marca-lncc-v-1-1-2023.pdf.
%
% The colors are defined according to the guidelines provided in the manual, ensuring compliance with the visual identity standards.
%
% Adapted by: José Renato Duarte Fajardo, LNCC, 2024.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{LNCCcolor}[v1.1]

\RequirePackage{xcolor}

% Main color
\definecolor{LNCCmainblue}{RGB/cmyk}{                0,  94, 161 / 100,  52,   2,  12} % PANTONE 2945 PC

